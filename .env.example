# ── Identity ──
INSTANCE_ID=sb
INSTANCE_NAME=StatusBlessed
BRAND_NAME=Status Blessed

# ── Domains ──
ADMIN_DOMAIN=agent.status-blessed.com
API_DOMAIN=api.status-blessed.com
API_PORT=3100
ADMIN_PORT=3101

# ── Default admin credentials (first boot only; hashed at seed) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=SB-change-me-2026!

# ── Database ──
DATABASE_URL=postgresql://sb_agent:PASSWORD@localhost:5432/sb_agent

# ── CRM ──
CRM_PROVIDER=keycrm
KEYCRM_API_KEY=
KEYCRM_SYNC_INTERVAL_MIN=30

# ── Meta / Instagram ──
META_APP_ID=
META_APP_SECRET=
IG_PAGE_ACCESS_TOKEN=
IG_PAGE_ID=
IG_WEBHOOK_VERIFY_TOKEN=sb-verify-2026

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_GROUP_ID=
TELEGRAM_ADMIN_PASSWORD=SB-tg-admin!

# ── Claude ──
CLAUDE_MAX_CONCURRENCY=2
CLAUDE_TIMEOUT_MS=30000
CLAUDE_MODEL=sonnet

# ── Auth ──
JWT_SECRET=replace-with-random-64-chars
JWT_EXPIRES_IN=7d

# Shared secret between super-admin and this tenant backend.
# Super-admin passes it as X-Supervisor-Token to /supervisor/* routes.
# Keep empty to disable the supervisor chat endpoint.
SUPERVISOR_SHARED_SECRET=

# ── File storage ──
UPLOADS_DIR=/opt/sb-agent/uploads

# Per-tenant knowledge & prompts directory (lives OUTSIDE the repo).
# Leave empty to auto-resolve to $HOME/tenant_knowledge — which means
# every Linux user hosting a tenant gets their own copy under their
# home (e.g. /home/blessed/tenant_knowledge). Override here only if
# you want a non-default location.
TENANT_KNOWLEDGE_DIR=

# -- Nova Poshta --
NOVA_POSHTA_API_KEY=

# -- Logging --
LOG_LEVEL=info
