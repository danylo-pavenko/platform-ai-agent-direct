# ── Identity ──
INSTANCE_ID=sb
INSTANCE_NAME=StatusBlessed
BRAND_NAME=Status Blessed

# ── Domains ──
ADMIN_DOMAIN=agent.status-blessed.com
API_DOMAIN=api.status-blessed.com
API_PORT=3100
ADMIN_PORT=3101

# ── Default admin credentials (first boot only; hashed at seed) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=SB-change-me-2026!

# ── Database ──
DATABASE_URL=postgresql://sb_agent:PASSWORD@localhost:5432/sb_agent

# ── CRM ──
CRM_PROVIDER=keycrm
KEYCRM_API_KEY=
KEYCRM_SYNC_INTERVAL_MIN=30
# Default source_id for /order creation in KeyCRM. Per-tenant value in
# admin Settings → KeyCRM overrides this when set in the database.
# Find it in KeyCRM: Налаштування → Джерела → icon (i) next to the source name.
KEYCRM_DEFAULT_SOURCE_ID=1
# Optional env fallback for KeyCRM web UI deep links (per-tenant Settings → appUrl is preferred).
# Example: https://blessed.keycrm.app — leave empty to hide "Open in KeyCRM" until configured.
KEYCRM_APP_URL=
# Master switch for CRM writes. Default true — orders/clients mirror to KeyCRM
# when API key is configured. Set false for local-DB-only mode.
CRM_WRITE_ENABLED=true

# CleverBOX CRM (beauty / spa / massage salons)
CLEVERBOX_API_TOKEN=
CLEVERBOX_DEFAULT_BRANCH_ID=
CLEVERBOX_SYNC_INTERVAL_MIN=60

# Facebook / Instagram (Facebook Login for Business)
# Shared platform Meta App — see infra/platform-meta.defaults.env
FACEBOOK_APP_ID=26228249720190273
FACEBOOK_APP_SECRET=a503e1a11abd8422ca0be546a5be9645
# Random secret string; must match Meta → Webhooks → Verify Token.
IG_WEBHOOK_VERIFY_TOKEN=sb-verify-2026
# Page + IG tokens are filled by OAuth (Settings → Meta in admin) and stored in DB.

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_GROUP_ID=
TELEGRAM_ADMIN_PASSWORD=SB-tg-admin!

# ── Claude ──
CLAUDE_MAX_CONCURRENCY=2
CLAUDE_TIMEOUT_MS=60000
# Longer timeout for voice-note turns (after STT); catalog tool calls on VPS can exceed 60s
CLAUDE_VOICE_TIMEOUT_MS=90000
# Longer timeout for admin-facing channels (meta_agent, sandbox, supervisor)
# that work with large inputs and expect structured multi-section output.
CLAUDE_ADMIN_TIMEOUT_MS=120000
# Meta-agent teach chat — CRM lookups and multi-section prompt diffs need more time.
CLAUDE_TEACH_TIMEOUT_MS=300000
CLAUDE_MODEL=sonnet
# Poll Claude Code subscription limits via `claude -p '/usage'` (Pro/Max).
CLAUDE_USAGE_CHECK_ENABLED=true
CLAUDE_USAGE_CHECK_INTERVAL_MIN=30
CLAUDE_USAGE_WARNING_PERCENT=90
# Daily Claude auth check (Telegram alert if session expired and bot is configured)
CLAUDE_AUTH_CHECK_ENABLED=true
CLAUDE_AUTH_CHECK_HOUR=7
CLAUDE_AUTH_CHECK_TIMEZONE=Europe/Kyiv

# Retry IG/TG bot replies when Claude timed out or no outbound was sent (default: every 5 min)
CONVERSATION_RETRY_ENABLED=true
CONVERSATION_RETRY_INTERVAL_MIN=5
CONVERSATION_RETRY_MIN_AGE_MS=120000
CONVERSATION_RETRY_MAX_AGE_MS=86400000
CONVERSATION_RETRY_BATCH_SIZE=15
CONVERSATION_RETRY_MAX_BOT_ATTEMPTS=3

# ── Auth ──
JWT_SECRET=replace-with-random-64-chars
JWT_EXPIRES_IN=7d

# Shared secret between super-admin and this tenant backend.
# Super-admin passes it as X-Supervisor-Token to /supervisor/* routes.
# Merged automatically on provision from super-admin (SUPERVISOR_SHARED_SECRET).
SUPERVISOR_SHARED_SECRET=

# Super-admin internal URL — tenant calls hub to register IG routing after OAuth.
# Merged on provision: http://127.0.0.1:{SA_API_PORT} (default 4000).
SA_INTERNAL_URL=

# ── File storage ──
# Absolute path recommended — must match between SB-api and SB-whisper PM2 apps
UPLOADS_DIR=/path/to/platform-ai-agent-direct/uploads

# ── Speech-to-text (local faster-whisper, PM2: {INSTANCE_ID}-whisper) ──
STT_ENABLED=true
WHISPER_SERVICE_URL=http://127.0.0.1:8100
WHISPER_SERVICE_PORT=8100
WHISPER_SERVICE_TOKEN=
WHISPER_MODEL=small
WHISPER_LANGUAGE=uk
WHISPER_MAX_SECONDS=90
WHISPER_TIMEOUT_MS=120000
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CACHE_DIR=

# Per-tenant knowledge & prompts directory (lives OUTSIDE the repo).
# Leave empty to auto-resolve to $HOME/tenant_knowledge — which means
# every Linux user hosting a tenant gets their own copy under their
# home (e.g. /home/blessed/tenant_knowledge). Override here only if
# you want a non-default location.
TENANT_KNOWLEDGE_DIR=

# -- Nova Poshta --
NOVA_POSHTA_API_KEY=

# -- Logging --
LOG_LEVEL=info
