{
  "name": "super-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=prisma/schema.prisma",
    "db:push": "prisma db push --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/jwt": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "@prisma/client": "^6.0.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "pino-pretty": "^13.0.0",
    "typescript": "^5.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.19.0"
  }
}
