generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId        String   @unique @map("instance_id")
  name              String
  apiDomain         String   @map("api_domain")
  adminDomain       String   @map("admin_domain")
  apiPort           Int      @map("api_port")
  adminPort         Int      @map("admin_port")
  linuxUser         String   @map("linux_user")
  appDir            String   @map("app_dir")
  status            String   @default("provisioned")
  gitRepo           String?  @map("git_repo")
  envExtra          String?  @map("env_extra")
  // Instagram / Meta webhook routing.
  // instagramUserId: entry[].id from Meta instagram-object webhooks = IG Business Account ID.
  //   Auto-populated when the tenant completes Facebook OAuth in their admin panel.
  // facebookAppSecret: tenant's Meta App Secret for hub HMAC verification.
  //   Auto-populated on OAuth success; can also be set manually by super-admin.
  instagramUserId     String?  @unique @map("instagram_user_id")
  // Additional IDs seen in webhook recipient.id / entry.id (Graph ig_id, etc.)
  instagramRoutingIds Json     @default("[]") @map("instagram_routing_ids")
  facebookAppSecret   String?  @map("facebook_app_secret")
  // Admin-panel access control (subscription-ready).
  // null = unlimited (perpetual) access — the default for every tenant.
  // A timestamp = access allowed until that moment; afterwards the tenant's
  // admin panel rejects logins/requests with a "payment required" message.
  // Manual blocking is done via status = 'suspended' (wins over any date).
  accessExpiresAt   DateTime? @map("access_expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}
