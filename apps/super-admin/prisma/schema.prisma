generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  instanceId        String   @unique @map("instance_id")
  name              String
  apiDomain         String   @map("api_domain")
  adminDomain       String   @map("admin_domain")
  apiPort           Int      @map("api_port")
  adminPort         Int      @map("admin_port")
  linuxUser         String   @map("linux_user")
  appDir            String   @map("app_dir")
  status            String   @default("provisioned")
  gitRepo           String?  @map("git_repo")
  envExtra          String?  @map("env_extra")
  // Instagram / Meta webhook routing.
  // instagramUserId: entry[].id from Meta instagram-object webhooks = IG Business Account ID.
  //   Auto-populated when the tenant completes Facebook OAuth in their admin panel.
  // facebookAppSecret: tenant's Meta App Secret for hub HMAC verification.
  //   Auto-populated on OAuth success; can also be set manually by super-admin.
  instagramUserId     String?  @unique @map("instagram_user_id")
  // Additional IDs seen in webhook recipient.id / entry.id (Graph ig_id, etc.)
  instagramRoutingIds Json     @default("[]") @map("instagram_routing_ids")
  facebookAppSecret   String?  @map("facebook_app_secret")
  // Admin-panel access control (subscription-ready).
  // null = unlimited (perpetual) access — the default for every tenant.
  // A timestamp = access allowed until that moment; afterwards the tenant's
  // admin panel rejects logins/requests with a "payment required" message.
  // Manual blocking is done via status = 'suspended' (wins over any date).
  accessExpiresAt   DateTime? @map("access_expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("tenants")
}

model TrackedLink {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String      @unique
  name            String
  destinationUrl  String      @map("destination_url")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  clicks          LinkClick[]
  leads           LandingLead[]

  @@map("tracked_links")
}

model LinkClick {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  linkId        String      @map("link_id") @db.Uuid
  link          TrackedLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  ip            String?
  userAgent     String?     @map("user_agent")
  referer       String?
  isBot         Boolean     @default(false) @map("is_bot")
  isPreview     Boolean     @default(false) @map("is_preview")
  isHuman       Boolean     @default(false) @map("is_human")
  country       String?
  countryCode   String?     @map("country_code")
  region        String?
  clickedAt     DateTime    @default(now()) @map("clicked_at")

  @@index([linkId, clickedAt])
  @@index([linkId, isHuman])
  @@map("link_clicks")
}

model LandingLead {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  linkId        String?      @map("link_id") @db.Uuid
  link          TrackedLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
  refSlug       String?      @map("ref_slug")
  name          String?
  email         String?
  instagram     String?
  messenger     String?
  message       String?
  plan          String?
  lang          String?
  pageUrl       String?      @map("page_url")
  referer       String?
  ip            String?
  userAgent     String?      @map("user_agent")
  country       String?
  countryCode   String?      @map("country_code")
  region        String?
  emailSent     Boolean      @default(false) @map("email_sent")
  emailError    String?      @map("email_error")
  status        String       @default("new")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([linkId])
  @@index([status])
  @@map("landing_leads")
}
